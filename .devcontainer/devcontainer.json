{
  "name": "CountingPhotons Python Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.interactiveWindow.textEditor.executeSelection": true,
        "jupyter.kernels.excludePythonEnvironments": [
          "/bin/python3",
          "/usr/bin/python3",
          "/usr/bin/python3.*",
          "/bin/python3.*"
        ]
      }
    }
  },
  "postCreateCommand": "pip install -r requirements/requirements.txt && python -m ipykernel install --user --name python3 --display-name 'Python 3'",
  "remoteUser": "vscode"
}
